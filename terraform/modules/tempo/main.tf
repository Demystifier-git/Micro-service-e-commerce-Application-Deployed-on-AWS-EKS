#########################################################
# GRAFANA TEMPO
#########################################################

resource "helm_release" "tempo" {

  name       = "tempo"
  repository = "https://grafana.github.io/helm-charts"
  chart      = "tempo"

  namespace        = "monitoring"
  create_namespace = false

  wait    = true
  timeout = 600

  values = [
    yamlencode({

      #####################################################
      # TEMPO CONFIG
      #####################################################
      tempo = {

        ###################################################
        # TRACE STORAGE
        ###################################################
        storage = {
          trace = {
            backend = "local"

            local = {
              path = "/var/tempo/traces"
            }
          }
        }

        ###################################################
        # RETENTION
        ###################################################
        retention = "24h"
      }

      #####################################################
      # SINGLE REPLICA (LIGHTWEIGHT DEV)
      #####################################################
      replicas = 1

      #####################################################
      # RESOURCE LIMITS
      #####################################################
      resources = {
        requests = {
          cpu    = "100m"
          memory = "256Mi"
        }

        limits = {
          cpu    = "500m"
          memory = "512Mi"
        }
      }

      #####################################################
      # OTEL RECEIVERS
      #####################################################
      receivers = {
        otlp = {
          protocols = {
            grpc = {}
            http = {}
          }
        }
      }

      #####################################################
      # SERVICE
      #####################################################
      service = {
        type = "ClusterIP"
      }

      #####################################################
      # PERSISTENCE OFF (DEV)
      #####################################################
      persistence = {
        enabled = false
      }
    })
  ]
}